            "股票涨跌额",
            "股票成交量",
            "股票成交额",
            "股票振幅",
            "股票换手率",
            "股票量比",
            "股票开盘价",
            "股票最高价",
            "股票最低价",
            "股票昨收价",
            "股票总市值",
            "股票流通市值",
            "股票市盈率动态",
            "股票市盈率TTM",
            "股票市净率",
