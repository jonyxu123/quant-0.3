    def __init__(
        self,
        min_request_interval: float = 0.8,
        timeout: int = 10,
        max_retries: int = 3,
        snapshot_cache_seconds: int = 5,
    ):
        self.min_request_interval = min_request_interval
        self.timeout = timeout
        self.max_retries = max_retries
        self.snapshot_cache_seconds = snapshot_cache_seconds

        self.last_request_time = 0.0

        self.session = requests.Session()
        self.session.headers.update({
            "User-Agent": (
                "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                "AppleWebKit/537.36 (KHTML, like Gecko) "
                "Chrome/132.0.0.0 Safari/537.36"
            ),
            "Referer": "https://quote.eastmoney.com/center/boardlist.html",
            "Accept": "application/json,text/plain,*/*",
        })

        # 盘中实时板块快照缓存
        self.board_snapshot_cache: pd.DataFrame = pd.DataFrame()
        self.board_snapshot_ts: float = 0.0

        # 板块成分股缓存，建议每日盘前/启动时刷新一次
        self.board_members_cache: pd.DataFrame = pd.DataFrame()
        self.board_members_ts: float = 0.0

    def _rate_limit(self):
        now = time.time()
        elapsed = now - self.last_request_time

        if elapsed < self.min_request_interval:
            time.sleep(self.min_request_interval - elapsed)

        time.sleep(random.uniform(0.05, 0.2))
        self.last_request_time = time.time()

    @staticmethod
    def _safe_numeric(df: pd.DataFrame, columns: list[str]) -> pd.DataFrame:
        for col in columns:
            if col in df.columns:
                df[col] = pd.to_numeric(df[col], errors="coerce")
        return df

    @staticmethod
    def normalize_stock_code(code: str) -> str:
        """
        将股票代码统一成 000001.SZ / 600000.SH / 430000.BJ 格式。
        """
        if code is None:
            return ""

        code = str(code).strip().upper()

        if not code:
            return ""

        if "." in code:
            raw, market = code.split(".", 1)
            raw = raw.zfill(6)
            return f"{raw}.{market}"

        code = code.zfill(6)

        if code.startswith("6"):
            return f"{code}.SH"

        if code.startswith("8") or code.startswith("4"):
            return f"{code}.BJ"

        return f"{code}.SZ"

    @staticmethod
    def _build_stock_code(code, market) -> str:
        if pd.isna(code):
            return ""

        code = str(code).strip()

        if not code or code == "-":
            return ""

        if code.isdigit() and len(code) < 6:
            code = code.zfill(6)

        try:
            market = int(market)
        except Exception:
            market = None

        if market == 0:
            return f"{code}.SZ"
        elif market == 1:
            return f"{code}.SH"
        elif market == 2:
            return f"{code}.BJ"
        else:
            return EastMoneyBoardService.normalize_stock_code(code)

    def _request_clist(self, params: dict) -> dict:
        last_error: Optional[Exception] = None

        for attempt in range(1, self.max_retries + 1):
            try:
                self._rate_limit()

                response = self.session.get(
                    self.URL,
                    params=params,
                    timeout=self.timeout,
                )
                response.raise_for_status()

                data = response.json()

                if not data.get("data"):
                    raise RuntimeError(f"东方财富返回空 data: {data}")

                return data

            except Exception as e:
                last_error = e
                wait_seconds = min(3 * attempt, 15)

                logging.warning(
                    "东方财富请求失败，第 %s/%s 次重试，等待 %s 秒，原因：%s",
                    attempt,
                    self.max_retries,
                    wait_seconds,
                    e,
                )

                time.sleep(wait_seconds)

        raise RuntimeError(f"东方财富请求最终失败：{last_error}")

    def _fetch_paged(
        self,
        fs: str,
        fields: str,
        page_size: int = 500,
        sort_field: str = "f3",
    ) -> pd.DataFrame:
        all_rows = []
        page = 1
        total = None

        while True:
            params = {
                "pn": str(page),
                "pz": str(page_size),
                "po": "1",
                "np": "1",
                "ut": "bd1d9ddb04089700cf9c27f6f7426281",
                "fltt": "2",
                "invt": "2",
                "fid": sort_field,
                "fs": fs,
                "fields": fields,
                "_": str(int(time.time() * 1000)),
            }

            data = self._request_clist(params)
            payload = data.get("data") or {}

            rows = payload.get("diff") or []
            total = payload.get("total", total)

            if not rows:
                break

            all_rows.extend(rows)

            if total is not None and len(all_rows) >= int(total):
                break

            if len(rows) < page_size:
                break

            page += 1

        if not all_rows:
            return pd.DataFrame()

        return pd.DataFrame(all_rows)

    def fetch_boards(self, board_type: BoardType) -> pd.DataFrame:
        """
        获取概念板块或行业板块实时快照。
        """
        if board_type not in self.BOARD_FS:
            raise ValueError("board_type 只能是 concept 或 industry")

        fields = (
            "f2,f3,f4,f5,f6,f8,"
            "f12,f14,f20,"
            "f104,f105,"
            "f128,f136,f140,f141"
        )

        raw_df = self._fetch_paged(
            fs=self.BOARD_FS[board_type],
            fields=fields,
            page_size=500,
            sort_field="f3",
        )

        if raw_df.empty:
            return raw_df

        df = raw_df.rename(columns=self.BOARD_FIELD_MAP).copy()
        df["采集时间"] = pd.Timestamp.now()
        df["板块类型"] = self.BOARD_NAME[board_type]

        df = self._safe_numeric(df, self.BOARD_NUMERIC_COLUMNS)

        df["领涨股票完整代码"] = df.apply(
            lambda row: self._build_stock_code(
                row.get("领涨股票代码"),
                row.get("领涨股票市场"),
            ),
            axis=1,
        )

        total_count = df["上涨家数"].fillna(0) + df["下跌家数"].fillna(0)
        denominator = total_count.mask(total_count == 0)

        df["上涨占比"] = df["上涨家数"] / denominator
        df["上涨占比"] = pd.to_numeric(df["上涨占比"], errors="coerce").round(4)

        keep_cols = [
            "采集时间",
            "板块类型",
            "板块代码",
            "板块名称",
            "最新价",
            "涨跌幅",
            "涨跌额",
            "成交量",
            "成交额",
            "换手率",
            "总市值",
            "上涨家数",
            "下跌家数",
            "上涨占比",
            "领涨股票",
            "领涨股票代码",
            "领涨股票市场",
            "领涨股票完整代码",
            "领涨股票涨跌幅",
        ]

        for col in keep_cols:
            if col not in df.columns:
                df[col] = None

        df = df[keep_cols]
        df = df.sort_values("涨跌幅", ascending=False, na_position="last")
        df = df.reset_index(drop=True)

        return df

    def fetch_all_boards_snapshot(self) -> pd.DataFrame:
        """
        获取所有概念板块 + 行业板块实时快照。
        """
        concept_df = self.fetch_boards("concept")
        industry_df = self.fetch_boards("industry")

        dfs = []

        if not concept_df.empty:
            dfs.append(concept_df)

        if not industry_df.empty:
            dfs.append(industry_df)

        if not dfs:
            return pd.DataFrame()

        df = pd.concat(dfs, ignore_index=True)
        df = self.score_boards(df)

        return df

    def get_board_snapshot(self, force: bool = False) -> pd.DataFrame:
        """
        获取板块实时快照。

        默认使用短缓存，避免多个模块重复请求。
        """
        now = time.time()

        if (
            not force
            and not self.board_snapshot_cache.empty
            and now - self.board_snapshot_ts <= self.snapshot_cache_seconds
        ):
            return self.board_snapshot_cache.copy()

        df = self.fetch_all_boards_snapshot()

        self.board_snapshot_cache = df.copy()
        self.board_snapshot_ts = time.time()

        return df.copy()

    def score_boards(self, df: pd.DataFrame) -> pd.DataFrame:
        """
        给板块打分。

        分数用于择时/T+0：
        - 涨跌幅越高越强
        - 成交额越大越强
        - 上涨占比越高越强
        - 领涨股票涨幅越高越强
        """
        if df.empty:
            return df

        df = df.copy()

        score_fields = [
            "涨跌幅",
            "成交额",
            "上涨占比",
            "领涨股票涨跌幅",
        ]

        for field in score_fields:
            if field not in df.columns:
                df[field] = 0

            df[field] = pd.to_numeric(df[field], errors="coerce").fillna(0)

        # 在概念板块、行业板块内部各自排名，避免行业数量少被概念板块淹没
        df["涨跌幅分位"] = df.groupby("板块类型")["涨跌幅"].rank(pct=True)
        df["成交额分位"] = df.groupby("板块类型")["成交额"].rank(pct=True)
        df["上涨占比分位"] = df.groupby("板块类型")["上涨占比"].rank(pct=True)
        df["领涨股分位"] = df.groupby("板块类型")["领涨股票涨跌幅"].rank(pct=True)

        df["板块强度分"] = (
            df["涨跌幅分位"] * 45
            + df["成交额分位"] * 25
            + df["上涨占比分位"] * 20
            + df["领涨股分位"] * 10
        ).round(2)

        df = df.sort_values(
            ["板块类型", "板块强度分", "涨跌幅"],
            ascending=[True, False, False],
            na_position="last",
        ).reset_index(drop=True)

        return df

    def get_strong_boards(
        self,
        min_pct: float = 1.0,
        min_up_ratio: float = 0.55,
        min_amount: float = 500_000_000,
        min_score: float = 65,
        top_n_each_type: Optional[int] = None,
        force_refresh: bool = False,
    ) -> pd.DataFrame:
        """
        获取强势板块，给择时模块使用。
        """
        df = self.get_board_snapshot(force=force_refresh)

        if df.empty:
            return pd.DataFrame()

        strong = df[
            (df["涨跌幅"] >= min_pct)
            & (df["上涨占比"] >= min_up_ratio)
            & (df["成交额"] >= min_amount)
            & (df["板块强度分"] >= min_score)
        ].copy()

        strong = strong.sort_values(
            ["板块类型", "板块强度分", "涨跌幅", "成交额"],
            ascending=[True, False, False, False],
        )

        if top_n_each_type is not None:
            strong = (
                strong.groupby("板块类型", group_keys=False)
                .head(top_n_each_type)
                .reset_index(drop=True)
            )

        return strong.reset_index(drop=True)

