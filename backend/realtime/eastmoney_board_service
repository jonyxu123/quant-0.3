    def refresh_members_cache(
        self,
        boards_df: Optional[pd.DataFrame] = None,
        max_boards: Optional[int] = None,
    ) -> pd.DataFrame:
        """
        刷新板块成分股缓存。

        建议：
        - 启动时刷新一次
        - 每天盘前刷新一次
        - 不要盘中每5秒刷新
        """
        if boards_df is None:
            boards_df = self.get_board_snapshot(force=True)

        if boards_df.empty:
            self.board_members_cache = pd.DataFrame()
            return self.board_members_cache

        work_df = boards_df[["板块类型", "板块代码", "板块名称"]].drop_duplicates()

        if max_boards is not None:
            work_df = work_df.head(max_boards)

        result = []
        total = len(work_df)

        for idx, row in enumerate(work_df.itertuples(index=False), start=1):
            board_type = getattr(row, "板块类型")
            board_code = getattr(row, "板块代码")
            board_name = getattr(row, "板块名称")

            logging.info(
                "刷新成分股缓存：%s/%s %s %s %s",
                idx,
                total,
                board_type,
                board_code,
                board_name,
            )

            try:
                member_df = self.fetch_board_members(
                    board_code=board_code,
                    board_name=board_name,
                    board_type_name=board_type,
                )

                if not member_df.empty:
                    result.append(member_df)

            except Exception as e:
                logging.exception(
                    "获取成分股失败：%s %s %s，原因：%s",
                    board_type,
                    board_code,
                    board_name,
                    e,
                )

        if result:
            self.board_members_cache = pd.concat(result, ignore_index=True)
        else:
            self.board_members_cache = pd.DataFrame()

        self.board_members_ts = time.time()

        logging.info(
            "板块成分股缓存刷新完成，行数：%s",
            len(self.board_members_cache),
        )

        return self.board_members_cache.copy()

    def get_members_for_boards(
        self,
        boards_df: pd.DataFrame,
        lazy_fetch_if_cache_empty: bool = True,
    ) -> pd.DataFrame:
        """
        根据板块列表获取成分股。

        优先使用缓存；
        如果缓存为空，可以只拉取传入板块的成分股。
        """
        if boards_df.empty:
            return pd.DataFrame()

        board_keys = boards_df[["板块类型", "板块代码", "板块名称"]].drop_duplicates()

        if not self.board_members_cache.empty:
            cache = self.board_members_cache.copy()

            merged = cache.merge(
                board_keys,
                on=["板块类型", "板块代码", "板块名称"],
                how="inner",
            )

            return merged.reset_index(drop=True)

        if not lazy_fetch_if_cache_empty:
            return pd.DataFrame()

        result = []

        for row in board_keys.itertuples(index=False):
            board_type = getattr(row, "板块类型")
            board_code = getattr(row, "板块代码")
            board_name = getattr(row, "板块名称")

            try:
                member_df = self.fetch_board_members(
                    board_code=board_code,
                    board_name=board_name,
                    board_type_name=board_type,
                )

                if not member_df.empty:
                    result.append(member_df)

            except Exception as e:
                logging.exception(
                    "懒加载成分股失败：%s %s %s，原因：%s",
                    board_type,
                    board_code,
                    board_name,
                    e,
                )

        if not result:
            return pd.DataFrame()

        return pd.concat(result, ignore_index=True)

    def build_candidate_pool_from_strong_boards(
        self,
        strong_boards: Optional[pd.DataFrame] = None,
        top_n_boards_each_type: int = 15,
        max_stocks: int = 100,
        lazy_fetch_members: bool = True,
    ) -> pd.DataFrame:
        """
        从强势板块中生成候选股票池。

        用途：
        - 给 Level2 订阅池
        - 给择时模块
        - 给 T+0 关注池
        """
        if strong_boards is None:
            strong_boards = self.get_strong_boards(
                top_n_each_type=top_n_boards_each_type,
                force_refresh=True,
            )

        if strong_boards.empty:
            return pd.DataFrame()

        members = self.get_members_for_boards(
            strong_boards,
            lazy_fetch_if_cache_empty=lazy_fetch_members,
        )

        if members.empty:
            return pd.DataFrame()

        board_cols = [
            "板块类型",
            "板块代码",
            "板块名称",
            "板块强度分",
            "涨跌幅",
            "成交额",
            "上涨占比",
            "领涨股票",
            "领涨股票完整代码",
            "领涨股票涨跌幅",
        ]

        board_info = strong_boards[board_cols].copy()
        board_info = board_info.rename(columns={
            "涨跌幅": "板块涨跌幅",
            "成交额": "板块成交额",
            "上涨占比": "板块上涨占比",
            "领涨股票": "板块领涨股票",
            "领涨股票完整代码": "板块领涨股票完整代码",
            "领涨股票涨跌幅": "板块领涨股票涨跌幅",
        })

        joined = members.merge(
            board_info,
            on=["板块类型", "板块代码", "板块名称"],
            how="inner",
        )

        if joined.empty:
            return pd.DataFrame()

        joined = joined.sort_values(
            ["股票完整代码", "板块强度分"],
            ascending=[True, False],
        )

        best_board = joined.drop_duplicates("股票完整代码").copy()

        agg = joined.groupby("股票完整代码").agg(
            股票名称=("股票名称", "first"),
            股票最新价=("股票最新价", "first"),
            股票涨跌幅=("股票涨跌幅", "first"),
            股票成交额=("股票成交额", "first"),
            股票换手率=("股票换手率", "first"),
            股票量比=("股票量比", "first"),
            所属强势板块数量=("板块代码", "nunique"),
            最高板块强度分=("板块强度分", "max"),
            平均板块强度分=("板块强度分", "mean"),
            最高板块涨跌幅=("板块涨跌幅", "max"),
        ).reset_index()

        best_cols = [
            "股票完整代码",
            "板块类型",
            "板块代码",
            "板块名称",
            "板块强度分",
            "板块涨跌幅",
            "板块成交额",
            "板块上涨占比",
        ]

        best_board = best_board[best_cols].rename(columns={
            "板块类型": "最强板块类型",
            "板块代码": "最强板块代码",
            "板块名称": "最强板块名称",
            "板块强度分": "最强板块强度分",
            "板块涨跌幅": "最强板块涨跌幅",
            "板块成交额": "最强板块成交额",
            "板块上涨占比": "最强板块上涨占比",
        })

        result = agg.merge(best_board, on="股票完整代码", how="left")

        result["候选股票评分"] = (
            result["最高板块强度分"] * 0.6
            + result["平均板块强度分"] * 0.25
            + result["所属强势板块数量"].clip(upper=5) * 3
            + result["股票涨跌幅"].fillna(0).clip(lower=-5, upper=10) * 1.2
        ).round(2)

        result = result.sort_values(
            ["候选股票评分", "最高板块强度分", "股票成交额"],
            ascending=[False, False, False],
            na_position="last",
        )

        result = result.reset_index(drop=True)

        if max_stocks is not None:
            result = result.head(max_stocks)

        return result

    def get_stock_board_exposure(
        self,
        stock_codes: Iterable[str],
        board_snapshot: Optional[pd.DataFrame] = None,
    ) -> pd.DataFrame:
        """
        查询某批股票属于哪些强势板块。

        用途：
        - T+0持仓股判断是否处于强势题材
        - 判断持仓是否应该优先做正T/倒T
        """
        if self.board_members_cache.empty:
            logging.warning("板块成分股缓存为空，请先调用 refresh_members_cache()")
            return pd.DataFrame()

        normalized_codes = {
            self.normalize_stock_code(code)
            for code in stock_codes
            if code
        }

        members = self.board_members_cache[
            self.board_members_cache["股票完整代码"].isin(normalized_codes)
        ].copy()

        if members.empty:
            return pd.DataFrame()

        if board_snapshot is None:
            board_snapshot = self.get_board_snapshot(force=False)

        if board_snapshot.empty:
            return members

        board_cols = [
            "板块类型",
            "板块代码",
            "板块名称",
            "板块强度分",
            "涨跌幅",
            "成交额",
            "上涨占比",
            "领涨股票",
            "领涨股票完整代码",
        ]

        board_info = board_snapshot[board_cols].copy()
        board_info = board_info.rename(columns={
            "涨跌幅": "板块涨跌幅",
            "成交额": "板块成交额",
            "上涨占比": "板块上涨占比",
            "领涨股票": "板块领涨股票",
            "领涨股票完整代码": "板块领涨股票完整代码",
        })

        joined = members.merge(
            board_info,
            on=["板块类型", "板块代码", "板块名称"],
            how="left",
        )

        joined["板块强度分"] = joined["板块强度分"].fillna(0)
        joined["板块涨跌幅"] = joined["板块涨跌幅"].fillna(0)
        joined["板块上涨占比"] = joined["板块上涨占比"].fillna(0)

        joined = joined.sort_values(
            ["股票完整代码", "板块强度分", "板块涨跌幅"],
            ascending=[True, False, False],
        )

        return joined.reset_index(drop=True)

    def build_t0_context(
        self,
        holdings: Optional[Iterable[str]] = None,
        watchlist: Optional[Iterable[str]] = None,
        top_n_boards_each_type: int = 15,
        max_candidate_stocks: int = 100,
    ) -> dict[str, pd.DataFrame]:
        """
        构建 T+0 / 择时模块的一次性上下文。

        返回：
        {
            "board_snapshot": 全部板块实时快照,
            "strong_boards": 强势板块,
            "candidate_pool": 强势板块候选股票池,
            "holding_exposure": 持仓股所属板块强弱,
            "watchlist_exposure": 自选股所属板块强弱,
        }
        """
        board_snapshot = self.get_board_snapshot(force=True)

        strong_boards = self.get_strong_boards(
            top_n_each_type=top_n_boards_each_type,
            force_refresh=False,
        )

        candidate_pool = self.build_candidate_pool_from_strong_boards(
            strong_boards=strong_boards,
            top_n_boards_each_type=top_n_boards_each_type,
            max_stocks=max_candidate_stocks,
            lazy_fetch_members=True,
        )

        holding_exposure = pd.DataFrame()
        watchlist_exposure = pd.DataFrame()

        if holdings:
            holding_exposure = self.get_stock_board_exposure(
                holdings,
                board_snapshot=board_snapshot,
            )

        if watchlist:
            watchlist_exposure = self.get_stock_board_exposure(
                watchlist,
                board_snapshot=board_snapshot,
            )

        return {
            "board_snapshot": board_snapshot,
            "strong_boards": strong_boards,
            "candidate_pool": candidate_pool,
            "holding_exposure": holding_exposure,
            "watchlist_exposure": watchlist_exposure,
        }


