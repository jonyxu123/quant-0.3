# Tushare Pro API Token（必填）
TUSHARE_TOKEN=your_tushare_token_here

# DuckDB 数据库路径（相对项目根目录或绝对路径）
DB_PATH=stock_data.duckdb
# 实时热库路径（可选；启用热冷分库时建议设置）
REALTIME_DB_PATH=realtime.duckdb

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 实时行情数据源：mootdx / gm
TICK_PROVIDER=mootdx

# gm 模式参数（仅当 TICK_PROVIDER=gm 时需要）
GM_TOKEN=your_gm_token_here
GM_MODE=1

# 是否允许实时失败时回退 mock（生产建议关闭）
REALTIME_ALLOW_MOCK_FALLBACK=0

# ==============================
# Realtime DB Writer（第三步）
# ==============================
# writer 批刷间隔（秒）
REALTIME_DB_WRITER_FLUSH_SEC=0.5

# 每批最大条数
REALTIME_DB_WRITER_MAX_BATCH=1000

# Redis 缓冲通道（可选，默认关闭）
REALTIME_DB_WRITER_REDIS_ENABLED=0
REALTIME_DB_WRITER_REDIS_URL=redis://127.0.0.1:6379/0
REALTIME_DB_WRITER_REDIS_LIST_KEY=quant:realtime:db_write

# Runtime health alert（连续黄/红告警）
RUNTIME_HEALTH_ALERT_ENABLED=1
RUNTIME_HEALTH_ALERT_CONSECUTIVE=3
RUNTIME_HEALTH_ALERT_COOLDOWN_SEC=300
RUNTIME_HEALTH_ALERT_MAX_EVENTS=200

# Runtime state Redis（质量滑窗 + 实时统计）
RUNTIME_STATE_REDIS_ENABLED=0
RUNTIME_STATE_REDIS_URL=redis://127.0.0.1:6379/0
RUNTIME_STATE_REDIS_KEY_PREFIX=quant:runtime
RUNTIME_STATE_REDIS_TTL_DAYS=7
RUNTIME_T0_QUALITY_WINDOW_SIZE=500

# Pool1 两阶段统计 Redis 持久化（可选，默认关闭）
POOL1_OBSERVE_REDIS_ENABLED=0
POOL1_OBSERVE_REDIS_URL=redis://127.0.0.1:6379/0
POOL1_OBSERVE_REDIS_KEY_PREFIX=quant:pool1:observe
POOL1_OBSERVE_REDIS_TTL_DAYS=7
